# ──────────────────────────────────────────────────────────────
#  NewsPulse AI — backend/.env
#  1. Copy this file and rename it to  .env
#  2. Fill in your real API keys below
#  3. NEVER commit the real .env to Git
# ──────────────────────────────────────────────────────────────

# PRIMARY news source — The Guardian (free, excellent India coverage)
# Get key: https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY= your_guardian_key
# FALLBACK news source — NewsAPI.org (free, 100 req/day)
# Get key: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key

# AI summarisation — Google Gemini 2.0 Flash (free tier)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key
